// ============================================================
// PURO AMOR KIDS — DATABASE SCHEMA
// Senior Data Architect Design
// ORM: Prisma  |  DB: PostgreSQL 15+
// Version: 1.0.0 | Date: 2026-03-02
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  MERCADOPAGO
  CASH
  CARD_DEBIT
  CARD_CREDIT
  BANK_TRANSFER
}

enum PaymentProvider {
  MERCADOPAGO
  CASH
  STRIPE
  MANUAL
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  IN_PROCESS
}

enum ShippingType {
  PICKUP       // Retiro en tienda
  HOME_DELIVERY // Envío a domicilio
}

enum StockLocation {
  WAREHOUSE  // Depósito
  STORE      // Local
  ONLINE     // Reservado para e-commerce
}

enum StockChangeReason {
  SALE           // Venta
  RESTOCK        // Reposición
  MANUAL_ADJUST  // Ajuste manual (conteo físico)
  RETURN         // Devolución
  DAMAGED        // Producto dañado/descartado
  TRANSFER       // Transferencia entre locaciones
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
  DISCONTINUED
}

enum Gender {
  MALE   // Niño
  FEMALE // Niña
  UNISEX // Bebé / No caminantes / Neutro
}

// ============================================================
// CATEGORIZATION LAYER
// Hierarchy: Category → ProductType → Product
// ============================================================

/// Main navigation categories: Niño, Niña, Bebé, No Caminantes
model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(50)  // e.g. "Niña", "Bebé"
  slug        String    @unique @db.VarChar(60)  // e.g. "nina", "bebe"
  gender      Gender
  description String?   @db.Text
  imageUrl    String?   @db.VarChar(500)
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  productTypes ProductType[]

  @@index([slug])
  @@index([isActive, sortOrder])
  @@map("categories")
}

/// Sub-categories: Remeras, Pantalones, Zapatillas, etc.
model ProductType {
  id          Int       @id @default(autoincrement())
  categoryId  Int
  name        String    @db.VarChar(80)   // e.g. "Remeras", "Zapatillas"
  slug        String    @unique @db.VarChar(100) // e.g. "zapatillas-nina"
  description String?   @db.Text
  imageUrl    String?   @db.VarChar(500)
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  category    Category  @relation(fields: [categoryId], references: [id])
  products    Product[]

  @@unique([categoryId, name])
  @@index([categoryId, isActive])
  @@map("product_types")
}

// ============================================================
// PRODUCT ENGINE
// Products → ProductVariants → Stock
// ============================================================

/// Base product entity (the "parent" card in the Product Explorer)
model Product {
  id            Int           @id @default(autoincrement())
  productTypeId Int
  name          String        @db.VarChar(200)
  slug          String        @unique @db.VarChar(250)
  description   String?       @db.Text
  basePrice     Decimal       @db.Decimal(10, 2)  // Precio base MXN/ARS
  brand         String?       @db.VarChar(100)
  status        ProductStatus @default(DRAFT)
  isFeatured    Boolean       @default(false)
  tags          String[]      // Array for quick filtering: ["nuevo", "sale"]
  createdAt     DateTime      @default(now()) @db.Timestamptz
  updatedAt     DateTime      @updatedAt @db.Timestamptz
  publishedAt   DateTime?     @db.Timestamptz

  productType   ProductType       @relation(fields: [productTypeId], references: [id])
  variants      ProductVariant[]
  images        ProductImage[]

  @@index([productTypeId, status])
  @@index([slug])
  @@index([status, isFeatured])
  @@index([createdAt(sort: Desc)]) // For "newest" sorting in Product Explorer
  @@map("products")
}

/// Each Product has one or more Variants (size + color combinations)
model ProductVariant {
  id          Int       @id @default(autoincrement())
  productId   Int
  sku         String    @unique @db.VarChar(100)  // e.g. "PAK-REM-NINA-M-ROJO"
  size        String    @db.VarChar(20)            // e.g. "4", "6", "M", "XL", "0-3M"
  color       String    @db.VarChar(50)            // e.g. "Rojo", "Azul Marino"
  colorHex    String?   @db.VarChar(7)             // e.g. "#FF5733" for UI swatches
  priceOffset Decimal   @default(0) @db.Decimal(10, 2) // Added to Product.basePrice
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  stock       Stock[]
  orderItems  OrderItem[]

  @@unique([productId, size, color]) // Prevents duplicate variant combos
  @@index([productId, isActive])
  @@index([sku])
  @@index([productId, color])  // For color filter in Product Explorer
  @@index([productId, size])   // For size filter in Product Explorer
  @@map("product_variants")
}

/// Gallery images for a product
model ProductImage {
  id         Int      @id @default(autoincrement())
  productId  Int
  url        String   @db.VarChar(500)
  altText    String?  @db.VarChar(200)
  isPrimary  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isPrimary])
  @@map("product_images")
}

// ============================================================
// INVENTORY ENGINE
// Real-time stock control with location awareness
// ============================================================

/// Real-time stock per variant per location
/// CRITICAL: Uses optimistic locking via 'version' column for race conditions
model Stock {
  id          Int           @id @default(autoincrement())
  variantId   Int
  location    StockLocation @default(ONLINE)
  quantity    Int           @default(0)
  reserved    Int           @default(0)  // Units in open orders (not yet paid)
  version     Int           @default(0)  // Optimistic locking counter
  updatedAt   DateTime      @updatedAt @db.Timestamptz

  /// available = quantity - reserved (computed in query layer)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  logs        InventoryLog[]

  @@unique([variantId, location])
  @@index([variantId])
  @@index([quantity])           // For "in stock" filter in Product Explorer
  @@map("stock")
}

/// Immutable audit log of every stock mutation
model InventoryLog {
  id           Int               @id @default(autoincrement())
  stockId      Int
  reason       StockChangeReason
  quantityDelta Int              // Positive = added, Negative = removed
  quantityAfter Int              // Snapshot of stock.quantity after change
  note         String?           @db.VarChar(500)  // Human-readable explanation
  orderId      Int?              // Linked order if reason = SALE | RETURN
  performedBy  String?           @db.VarChar(100)  // Admin user email/id
  createdAt    DateTime          @default(now()) @db.Timestamptz

  stock        Stock @relation(fields: [stockId], references: [id])

  @@index([stockId, createdAt(sort: Desc)])
  @@index([reason])
  @@map("inventory_logs")
}

// ============================================================
// CUSTOMER & ORDER FLOW
// ============================================================

/// Customer entity (can be guest or registered)
model Customer {
  id        Int      @id @default(autoincrement())
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  dni       String?  @db.VarChar(15)   // DNI argentino
  phone     String   @db.VarChar(20)   // For WhatsApp contact
  email     String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  orders    Order[]

  @@index([email])
  @@index([phone])
  @@index([dni])
  @@map("customers")
}

/// Core order entity
model Order {
  id             Int           @id @default(autoincrement())
  customerId     Int
  status         OrderStatus   @default(PENDING_PAYMENT)
  totalAmount    Decimal       @db.Decimal(10, 2)  // Final amount including shipping
  subtotal       Decimal       @db.Decimal(10, 2)  // Items total only
  shippingCost   Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  paymentMethod  PaymentMethod
  notes          String?       @db.Text            // Internal admin notes
  customerNote   String?       @db.Text            // Note from customer at checkout
  createdAt      DateTime      @default(now()) @db.Timestamptz
  updatedAt      DateTime      @updatedAt @db.Timestamptz
  paidAt         DateTime?     @db.Timestamptz
  shippedAt      DateTime?     @db.Timestamptz
  deliveredAt    DateTime?     @db.Timestamptz

  customer         Customer            @relation(fields: [customerId], references: [id])
  items            OrderItem[]
  shippingDetails  ShippingDetails?
  transactions     PaymentTransaction[]

  @@index([customerId])
  @@index([status, createdAt(sort: Desc)])  // Admin order dashboard
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

/// Snapshot of each item in an order at the time of purchase
/// CRITICAL: Prices are snapshotted — never join back to live product prices
model OrderItem {
  id              Int      @id @default(autoincrement())
  orderId         Int
  variantId       Int      // Soft reference — kept even if variant is deleted
  quantity        Int
  // ---- PRICE SNAPSHOT (immutable record of the sale price) ----
  unitPrice       Decimal  @db.Decimal(10, 2)   // Price at time of purchase
  totalPrice      Decimal  @db.Decimal(10, 2)   // unitPrice * quantity
  // ---- PRODUCT SNAPSHOT (for display even after product changes) ----
  productName     String   @db.VarChar(200)
  variantSku      String   @db.VarChar(100)
  variantSize     String   @db.VarChar(20)
  variantColor    String   @db.VarChar(50)
  // ---- METADATA ----
  createdAt       DateTime @default(now()) @db.Timestamptz

  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

// ============================================================
// SHIPPING
// Conditional: PICKUP vs HOME_DELIVERY
// ============================================================

model ShippingDetails {
  id           Int          @id @default(autoincrement())
  orderId      Int          @unique
  shippingType ShippingType

  // --- Only populated if HOME_DELIVERY ---
  streetAddress String?  @db.VarChar(300)
  apartment    String?   @db.VarChar(100)
  city         String?   @db.VarChar(100)
  province     String?   @db.VarChar(100)
  zipCode      String?   @db.VarChar(20)
  country      String    @default("Argentina") @db.VarChar(100)
  deliveryNote String?   @db.Text

  // --- Only populated if PICKUP ---
  pickupLocationName String? @db.VarChar(200)  // e.g. "Local Centro"
  estimatedPickupAt  DateTime? @db.Timestamptz

  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz

  order        Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("shipping_details")
}

// ============================================================
// PAYMENT TRANSACTIONS
// One Order can have multiple transaction attempts
// ============================================================

model PaymentTransaction {
  id            Int             @id @default(autoincrement())
  orderId       Int
  provider      PaymentProvider
  status        PaymentStatus   @default(PENDING)
  transactionId String?         @unique @db.VarChar(200) // External ID (MercadoPago preference ID)
  amount        Decimal         @db.Decimal(10, 2)
  currency      String          @default("ARS") @db.VarChar(5)
  receiptUrl    String?         @db.VarChar(500)   // WhatsApp-shareable receipt URL
  rawResponse   Json?                              // Full provider webhook payload
  createdAt     DateTime        @default(now()) @db.Timestamptz
  updatedAt     DateTime        @updatedAt @db.Timestamptz
  processedAt   DateTime?       @db.Timestamptz

  order         Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([transactionId])
  @@index([status])
  @@map("payment_transactions")
}
